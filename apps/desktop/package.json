{
  "//": "WARNING: Before upgrading opencode-ai, check sst/opencode for prompt changes (title.txt, compaction.txt, prompt.ts, compaction.ts). Downstream prompt-validation (if any) may need to be re-aligned if prefixes drift.",
  "name": "@accomplish/desktop",
  "version": "0.5.17",
  "private": true,
  "homepage": "https://accomplish.ai",
  "author": {
    "name": "Accomplish Inc",
    "email": "support@accomplish.ai"
  },
  "type": "module",
  "description": "Accomplish Desktop App",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "predev": "node scripts/predev.cjs",
    "dev": "node scripts/dev.cjs --local",
    "predev:clean": "node scripts/predev.cjs",
    "dev:clean": "node scripts/dev.cjs --local --clean",
    "predev:remote": "node scripts/predev.cjs",
    "dev:remote": "node scripts/dev.cjs --remote",
    "build:mcp-tools:dev": "node scripts/bundle-skills.cjs --mode=dev",
    "build:mcp-tools:package": "node scripts/bundle-skills.cjs --mode=package",
    "build:base": "pnpm -F @accomplish/web build && tsc && vite build",
    "build": "pnpm build:base && pnpm build:mcp-tools:dev",
    "build:electron": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && pnpm stage:daemon-deps && pnpm build:mcp-tools:package && node scripts/package.cjs",
    "build:unpack": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && pnpm stage:daemon-deps && pnpm build:mcp-tools:package && node scripts/package.cjs --dir",
    "package": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && pnpm stage:daemon-deps && pnpm build:mcp-tools:package && node scripts/package.cjs --mac --publish never",
    "package:mac": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && pnpm stage:daemon-deps && pnpm build:mcp-tools:package && node scripts/package.cjs --mac --publish never",
    "package:win": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && pnpm stage:daemon-deps && pnpm build:mcp-tools:package && node scripts/package.cjs --win --x64 --publish never",
    "package:linux:x64": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && node scripts/stage-daemon-deps.cjs --target-platform=linux-x64 && ACCOMPLISH_BUNDLED_MCP=1 pnpm build:mcp-tools:package && node scripts/package.cjs --linux --x64 --publish never",
    "package:linux:arm64": "pnpm download:nodejs && pnpm build:base && pnpm -F @accomplish/daemon build && node scripts/stage-daemon-deps.cjs --target-platform=linux-arm64 && ACCOMPLISH_BUNDLED_MCP=1 pnpm build:mcp-tools:package && node scripts/package.cjs --linux --arm64 --publish never",
    "package:linux": "pnpm package:linux:x64 && pnpm package:linux:arm64",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['dist','dist-electron','release'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "download:nodejs": "node scripts/download-nodejs.cjs",
    "stage:daemon-deps": "node scripts/stage-daemon-deps.cjs",
    "verify:package": "node scripts/assert-packaging-invariants.cjs",
    "smoke:packaged-opencode": "node scripts/smoke-packaged-opencode.cjs",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:e2e": "bash e2e/docker/run-e2e.sh",
    "test:e2e:build": "bash e2e/docker/run-e2e.sh --build-only",
    "test:e2e:clean": "docker rmi $(docker images 'accomplish-e2e' -q) 2>/dev/null || true",
    "test:e2e:report": "playwright show-report e2e/html-report",
    "test:e2e:native": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:native:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:native:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:native:fast": "playwright test --config=e2e/playwright.config.ts --project=electron-fast",
    "test:e2e:native:integration": "playwright test --config=e2e/playwright.config.ts --project=electron-integration",
    "test:e2e:providers": "playwright test --config=e2e/playwright.config.ts --project=provider-e2e",
    "test:local-agent": "npx tsx scripts/test-local-agent-cli.ts"
  },
  "dependencies": {
    "@accomplish_ai/agent-core": "workspace:*",
    "@aws-sdk/client-bedrock": "^3.971.0",
    "@aws-sdk/credential-providers": "^3.971.0",
    "@azure/identity": "^4.13.0",
    "@huggingface/transformers": "^4.0.1",
    "@sentry/electron": "^7.8.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "dotenv": "^17.2.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.7.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "mixpanel": "^0.21.0",
    "@opencode-ai/sdk": "1.14.26",
    "opencode-ai": "1.14.26",
    "pino": "^10.3.1",
    "proxy-from-env": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semver": "^7.7.0",
    "undici": "^8.0.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "catalog:",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/semver": "^7.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.2",
    "electron": "^41.0.2",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "opencode-darwin-arm64": "1.14.26",
    "opencode-darwin-x64": "1.14.26",
    "opencode-darwin-x64-baseline": "1.14.26",
    "opencode-linux-arm64": "1.14.26",
    "opencode-linux-arm64-musl": "1.14.26",
    "opencode-linux-x64": "1.14.26",
    "opencode-linux-x64-baseline": "1.14.26",
    "opencode-linux-x64-baseline-musl": "1.14.26",
    "opencode-linux-x64-musl": "1.14.26",
    "opencode-windows-x64": "1.14.26",
    "opencode-windows-x64-baseline": "1.14.26"
  },
  "build": {
    "npmRebuild": false,
    "compression": "normal",
    "appId": "ai.accomplish.desktop",
    "productName": "Accomplish",
    "artifactName": "Accomplish-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist-electron/**/*",
      "node_modules/opencode-ai/**",
      "node_modules/opencode-darwin-arm64/**",
      "node_modules/opencode-darwin-x64/**",
      "node_modules/opencode-darwin-x64-baseline/**",
      "node_modules/electron-store/**",
      "node_modules/conf/**",
      "node_modules/env-paths/**",
      "node_modules/json-schema-typed/**",
      "node_modules/atomically/**",
      "node_modules/debounce-fn/**",
      "node_modules/mixpanel/**",
      "node_modules/@sentry/**",
      "!node_modules/@accomplish_ai/**",
      "node_modules/opencode-linux-x64/**",
      "node_modules/opencode-linux-x64-baseline/**",
      "node_modules/opencode-linux-x64-musl/**",
      "node_modules/opencode-linux-x64-baseline-musl/**",
      "node_modules/opencode-linux-arm64/**",
      "node_modules/opencode-linux-arm64-musl/**",
      "node_modules/opencode-windows-x64/**",
      "node_modules/opencode-windows-x64-baseline/**",
      "node_modules/electron-updater/**",
      "node_modules/builder-util-runtime/**",
      "node_modules/js-yaml/**",
      "node_modules/lazy-val/**",
      "node_modules/lodash.escaperegexp/**",
      "node_modules/lodash.isequal/**",
      "node_modules/semver/**",
      "node_modules/tiny-typed-emitter/**",
      "node_modules/fs-extra/**",
      "node_modules/graceful-fs/**",
      "node_modules/jsonfile/**",
      "node_modules/universalify/**",
      "node_modules/argparse/**",
      "node_modules/debug/**",
      "node_modules/ms/**",
      "node_modules/sax/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../../packages/agent-core/mcp-tools",
        "to": "mcp-tools",
        "filter": [
          "**/*",
          "!**/profiles/**",
          "!**/tmp/**",
          "!**/.git/**",
          "!**/.browser-data/**",
          "!**/.ignored_*/**",
          "!**/bun.lock",
          "!**/*.test.ts",
          "!**/vitest.config.ts"
        ]
      },
      {
        "from": "../web/dist/client",
        "to": "web-ui"
      },
      {
        "from": "bundled-skills",
        "to": "bundled-skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../apps/daemon/dist",
        "to": "daemon"
      },
      {
        "from": "build.env",
        "to": "build.env"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/opencode-ai/bin/opencode",
      "node_modules/opencode-ai/bin/opencode.exe",
      "node_modules/opencode-ai/package.json",
      "node_modules/opencode-darwin-arm64/bin/opencode",
      "node_modules/opencode-darwin-arm64/package.json",
      "node_modules/opencode-darwin-x64/bin/opencode",
      "node_modules/opencode-darwin-x64/package.json",
      "node_modules/opencode-darwin-x64-baseline/bin/opencode",
      "node_modules/opencode-darwin-x64-baseline/package.json",
      "node_modules/opencode-windows-x64/bin/opencode.exe",
      "node_modules/opencode-windows-x64/package.json",
      "node_modules/opencode-windows-x64-baseline/bin/opencode.exe",
      "node_modules/opencode-windows-x64-baseline/package.json",
      "dist-electron/main/mcp/*.js",
      "node_modules/opencode-linux-x64/bin/opencode",
      "node_modules/opencode-linux-x64/package.json",
      "node_modules/opencode-linux-x64-baseline/bin/opencode",
      "node_modules/opencode-linux-x64-baseline/package.json",
      "node_modules/opencode-linux-x64-musl/bin/opencode",
      "node_modules/opencode-linux-x64-musl/package.json",
      "node_modules/opencode-linux-x64-baseline-musl/bin/opencode",
      "node_modules/opencode-linux-x64-baseline-musl/package.json",
      "node_modules/opencode-linux-arm64/bin/opencode",
      "node_modules/opencode-linux-arm64/package.json",
      "node_modules/opencode-linux-arm64-musl/bin/opencode",
      "node_modules/opencode-linux-arm64-musl/package.json"
    ],
    "afterPack": "./scripts/after-pack.cjs",
    "publish": {
      "provider": "github",
      "owner": "accomplish-ai",
      "repo": "accomplish"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "icon": "resources/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Accomplish",
      "runAfterFinish": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "resources/icon.png"
    }
  }
}
